{
  "name": "insurance-gpt-mcp-testing",
  "version": "1.0.0",
  "description": "Testing framework for Insurance GPT running over MCP",
  "main": "index.js",
  "scripts": {
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:e2e": "jest tests/e2e",
    "test:mcp": "jest tests/mcp",
    "test:api": "jest tests/api",
    "test:integration": "jest tests/integration"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.4",
    "axios": "^1.7.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": ["ts", "js", "json"],
    "testMatch": ["**/?(*.)+(test).[tj]s?(x)"],
    "roots": ["<rootDir>/tests"],
    "setupFilesAfterEnv": ["<rootDir>/tests/helpers/jest-setup.ts"]
  }
}
